# ClickHouse Cloud service metadata.
CLICKHOUSE_SERVICE_ID=

# Optional: lets the CLI resolve CLICKHOUSE_HOST from ClickHouse Cloud.
# ClickHouse Cloud API uses basic auth: key id + key secret.
CLICKHOUSE_CLOUD_KEY_ID=
CLICKHOUSE_CLOUD_KEY_SECRET=
CLICKHOUSE_ORGANIZATION_ID=

# ClickHouse SQL connection settings.
# If CLICKHOUSE_HOST is empty, use `twag-clickhouse resolve-cloud-service`
# after setting the cloud API credentials above.
CLICKHOUSE_HOST=
CLICKHOUSE_PORT=8443
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=

# Optional alias if your deployment calls the database password an API key.
# Used only when CLICKHOUSE_PASSWORD is empty.
CLICKHOUSE_API_KEY=

CLICKHOUSE_DATABASE=default
CLICKHOUSE_SECURE=true
CLICKHOUSE_CONNECT_TIMEOUT=10
CLICKHOUSE_SEND_RECEIVE_TIMEOUT=30

# Subconscious model endpoint for the NYTechWeek agent wrapper.
SUBCONSCIOUS_API_KEY=
SUBCONSCIOUS_BASE_URL=https://api.subconscious.dev/v1
SUBCONSCIOUS_MODEL=subconscious/tim-qwen3.6-27b
SUBCONSCIOUS_RUN_ENGINE=tim-gpt
SUBCONSCIOUS_MAX_TOKENS=1200

# Public ClickHouse query tool for Subconscious hosted runs.
NYTW_TOOL_URL=
NYTW_TOOL_TOKEN=
NYTW_TOOL_HOST=0.0.0.0
NYTW_TOOL_PORT=8000

# Telegram bot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_CLEAR_WEBHOOK_ON_POLL=true
TELEGRAM_POLL_TIMEOUT=30
