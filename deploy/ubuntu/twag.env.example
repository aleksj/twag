# Copy to /etc/twag/twag.env on the Ubuntu host.
# Keep this file private. Do not commit real values.

# ClickHouse SQL connection.
CLICKHOUSE_SERVICE_ID=
CLICKHOUSE_HOST=
CLICKHOUSE_PORT=8443
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_API_KEY=
CLICKHOUSE_DATABASE=default
CLICKHOUSE_SECURE=true
CLICKHOUSE_CONNECT_TIMEOUT=10
CLICKHOUSE_SEND_RECEIVE_TIMEOUT=30

# Optional ClickHouse Cloud resolution credentials.
CLICKHOUSE_CLOUD_KEY_ID=
CLICKHOUSE_CLOUD_KEY_SECRET=
CLICKHOUSE_ORGANIZATION_ID=

# Subconscious model endpoint.
SUBCONSCIOUS_API_KEY=
SUBCONSCIOUS_BASE_URL=https://api.subconscious.dev/v1
SUBCONSCIOUS_MODEL=subconscious/tim-qwen3.6-27b
SUBCONSCIOUS_RUN_ENGINE=tim-gpt
SUBCONSCIOUS_MAX_TOKENS=1200

# Telegram bot long-polling process.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_CLEAR_WEBHOOK_ON_POLL=true
TELEGRAM_POLL_TIMEOUT=30
TELEGRAM_AGENT_LOCK_FILE=/run/twag/telegram-agent.lock

# Public ClickHouse query tool / Nimble process defaults.
NYTW_TOOL_URL=
NYTW_TOOL_TOKEN=
NYTW_TOOL_HOST=0.0.0.0
NYTW_TOOL_PORT=8000
NYTW_TOOL_RELOAD=false

# Command used by twag-nimble.service.
# Override if your Nimble process is not the bundled query tool server.
TWAG_NIMBLE_COMMAND=.venv/bin/twag-nytw-tool-server
