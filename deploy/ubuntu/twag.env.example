# Copy to /etc/twag/twag.env on the Ubuntu host.
# Keep this file private. Do not commit real values.

# ClickHouse SQL connection.
CLICKHOUSE_SERVICE_ID=
CLICKHOUSE_HOST=
CLICKHOUSE_PORT=8443
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_API_KEY=
CLICKHOUSE_DATABASE=default
CLICKHOUSE_SECURE=true
CLICKHOUSE_CONNECT_TIMEOUT=10
CLICKHOUSE_SEND_RECEIVE_TIMEOUT=30
CLICKHOUSE_QUERY_RETRIES=3
CLICKHOUSE_RETRY_INITIAL_SECONDS=1
CLICKHOUSE_RETRY_MAX_SECONDS=8

# Optional ClickHouse Cloud resolution credentials.
CLICKHOUSE_CLOUD_KEY_ID=
CLICKHOUSE_CLOUD_KEY_SECRET=
CLICKHOUSE_ORGANIZATION_ID=

# Subconscious model endpoint.
SUBCONSCIOUS_API_KEY=
SUBCONSCIOUS_BASE_URL=https://api.subconscious.dev/v1
SUBCONSCIOUS_MODEL=subconscious/tim-qwen3.6-27b
SUBCONSCIOUS_RUN_ENGINE=tim-gpt
SUBCONSCIOUS_MAX_TOKENS=1200
SUBCONSCIOUS_ENABLE_THINKING=true

# Senso knowledge base mirror. The agent does not call Senso directly; the
# sync agent mirrors Senso into ClickHouse senso_* tables.
SENSO_API_KEY=
SENSO_BASE_URL=https://apiv2.senso.ai/api/v1
SENSO_ORG_ID=
SENSO_ORG_SLUG=
SENSO_SYNC_ENABLED=true
SENSO_SYNC_INTERVAL_SECONDS=3600
SENSO_SYNC_REPLACE=false
SENSO_SYNC_BATCH_SIZE=500
SENSO_CHUNK_CHARS=3500
SENSO_CHUNK_OVERLAP=300
SENSO_MAX_DOWNLOAD_BYTES=2000000

# Direct Tech Week calendar sync. This does not use Nimble or paid scraping
# APIs. It crawls the public NYC/Boston calendars, fetches changed Partiful
# detail pages gently, writes append-only calendar snapshots, exposes latest
# complete runs through <prefix>_current_events, and records row-level changes
# in <prefix>_sync_runs and <prefix>_sync_changes.
TECHWEEK_CALENDAR_SYNC_ENABLED=true
TECHWEEK_CALENDAR_SYNC_CITIES=nyc,boston
TECHWEEK_CALENDAR_SYNC_INTERVAL_SECONDS=21600
TECHWEEK_CALENDAR_SYNC_INCLUDE_INVITE_ONLY=false
TECHWEEK_EVENT_FETCH_CONCURRENCY=3
TECHWEEK_EVENT_FETCH_TIMEOUT_SECONDS=25
TECHWEEK_CALENDAR_SYNC_BATCH_SIZE=500
TECHWEEK_CALENDAR_MAX_SCROLL_TICKS=260
TECHWEEK_CALENDAR_SCROLL_DELAY_SECONDS=0.35
TECHWEEK_CALENDAR_PAGE_DELAY_SECONDS=0.1

# Telegram bot long-polling process. Set TELEGRAM_BOT_TOKEN for one unified
# /city-switching bot. If NYC_TELEGRAM_BOT_TOKEN and/or BOSTON_TELEGRAM_BOT_TOKEN
# are set instead, the same process polls each configured city account and uses
# that city as the default for new chats.
TWAG_SPONSOR_LINE="**Sponsored by Data.Flowers** - https://data.flowers/"
TELEGRAM_BOT_TOKEN=
NYC_TELEGRAM_BOT_TOKEN=
BOSTON_TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_CLEAR_WEBHOOK_ON_POLL=true
TELEGRAM_POLL_TIMEOUT=30
TELEGRAM_REQUEST_TIMEOUT=45
TELEGRAM_RETRY_INITIAL_SECONDS=2
TELEGRAM_RETRY_MAX_SECONDS=60
TELEGRAM_STATUS_HEARTBEAT_SECONDS=8
TELEGRAM_STREAM_DRAFTS=true
TELEGRAM_STREAM_DRAFT_INTERVAL_SECONDS=1
TELEGRAM_WARM_CLICKHOUSE_ON_START=true
TELEGRAM_AGENT_LOCK_FILE=/run/twag/telegram-agent.lock
TELEGRAM_QUESTION_LOG_PATH=/var/log/twag/questions.jsonl

# Browser terminal backend. Keep the default host local unless a reverse proxy
# on another host must reach this service.
TWAG_TERMINAL_HOST=localhost
TWAG_TERMINAL_PORT=8765
TWAG_TERMINAL_TOKEN=
TWAG_TERMINAL_ACCESS_LOG=false
TWAG_TERMINAL_LOG_LEVEL=info
TWAG_TERMINAL_SESSION_DIR=/var/log/twag/terminal-sessions
TWAG_TERMINAL_AGENT_MAX_TURNS=4
TWAG_TERMINAL_ENABLE_THINKING=false
TWAG_TERMINAL_QUERY_TIMEOUT_SECONDS=180
TWAG_TERMINAL_QUERY_HEARTBEAT_SECONDS=20
TWAG_TERMINAL_RESULT_MAPS_ENABLED=false
TWAG_PUBLIC_TERMINAL_BASE_URL=https://data.flowers/tw/terminal

# Public ClickHouse query tool / sync-agent process defaults.
NYTW_TOOL_URL=
NYTW_TOOL_TOKEN=
NYTW_TOOL_HOST=localhost
NYTW_TOOL_PORT=8000
NYTW_TOOL_RELOAD=false
NYTW_TOOL_ACCESS_LOG=false
NYTW_TOOL_SUPPRESS_SCANNER_NOISE=true
NYTW_TOOL_LOG_LEVEL=info

# Command used by twag-sync-agent.service.
TWAG_SYNC_AGENT_COMMAND=.venv/bin/twag-sync-agent
